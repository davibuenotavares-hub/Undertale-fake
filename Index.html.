<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Undertale Clone - GitHub Edition</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div id="game-container">
        <canvas id="gameCanvas"></canvas>
    </div>

    <div id="ui-container">
        <div class="stats">HP: <span id="hp">20</span> / 20</div>
        <div id="msg" class="dialog-box">Use o D-Pad para explorar e encontrar monstros...</div>
        
        <div id="battle-menu" class="buttons-grid" style="display: none;">
            <button onclick="handleAction('lutar')">LUTAR</button>
            <button onclick="handleAction('agir')">AGIR</button>
            <button onclick="handleAction('itens')">ITENS</button>
            <button onclick="handleAction('poupar')">POUPAR</button>
        </div>

        <div id="dpad">
            <div class="empty"></div>
            <button class="d-btn" id="up">↑</button>
            <div class="empty"></div>
            <button class="d-btn" id="left">←</button>
            <button class="d-btn" id="down">↓</button>
            <button class="d-btn" id="right">→</button>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
